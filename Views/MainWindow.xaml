<Window x:Class="FinanceiroObserver.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FinanceiroObserver.App"
        mc:Ignorable="d"
        Title="Monitor de Ações" Height="450" Width="800">
        
        <StackPanel Margin="20">
                <TextBlock Text="{Binding PrecoAtual}" 
                           FontSize="24" 
                           FontWeight="Bold"/>
        
                <ListBox ItemsSource="{Binding Historico}" 
                         Height="200" 
                         Margin="0,10,0,0"/>
        </StackPanel>
</Window>
